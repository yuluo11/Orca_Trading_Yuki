# Copy the provider block you want into `backend/.env`.
# Supported providers: `anthropic`, `claude`, `gemini`, `openai_compatible`, `mock`

# Claude / Anthropic
ORCA_LLM_PROVIDER=anthropic
ORCA_LLM_API_KEY=your_anthropic_api_key
ORCA_LLM_BASE_URL=https://api.anthropic.com
ORCA_LLM_MODEL=claude-sonnet-4-20250514
ORCA_LLM_TEMPERATURE=0.2
ORCA_LLM_TIMEOUT_SECONDS=60
ORCA_LLM_MAX_TOKENS=1024

# OpenAI-compatible
# ORCA_LLM_PROVIDER=openai_compatible
# ORCA_LLM_API_KEY=your_openai_compatible_api_key
# ORCA_LLM_BASE_URL=https://api.openai.com/v1
# ORCA_LLM_MODEL=gpt-5-mini
# ORCA_LLM_TEMPERATURE=0.2
# ORCA_LLM_TIMEOUT_SECONDS=60
# ORCA_LLM_MAX_TOKENS=1024

# Gemini
# ORCA_LLM_PROVIDER=gemini
# ORCA_LLM_API_KEY=your_google_ai_api_key
# ORCA_LLM_MODEL=gemini-2.5-flash
# ORCA_LLM_TEMPERATURE=0.2
# ORCA_LLM_TIMEOUT_SECONDS=60
# ORCA_LLM_MAX_TOKENS=1024

# Mock
# ORCA_LLM_PROVIDER=mock
# ORCA_LLM_MOCK_RESPONSE=
# ORCA_LLM_MOCK_JSON_RESPONSE={"summary":"Mock response"}
